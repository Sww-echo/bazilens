# =============================================================================
# Frontend env vars (Vite 注入到 import.meta.env)
# 复制本文件到 .env.local 并填入真实值。永远不要提交 .env.local
# =============================================================================

# --- Supabase ---
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# --- Stripe (Web 端可见) ---
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Sentry (可选，用户同意后才 init) ---
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# --- PostHog (可选，用户同意后才 init) ---
VITE_POSTHOG_KEY=phc_xxx
VITE_POSTHOG_HOST=https://app.posthog.com

# --- App 部署 URL（用于 OAuth 回调 / Stripe 跳转） ---
VITE_APP_URL=http://localhost:5173

# =============================================================================
# Edge Function env vars（不要在前端使用！通过 supabase secrets set 注入）
# 下面这些仅在 supabase functions 运行时可见（Deno.env.get）
# =============================================================================
# 命令：supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
#
# ANTHROPIC_API_KEY=sk-ant-...                                # Pro 档
# OPENAI_API_KEY=sk-...                                       # Plus 档
# DEEPSEEK_API_KEY=sk-...                                     # Free 档
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# REVENUECAT_WEBHOOK_AUTH=Bearer xxx                          # Sprint 2
# RESEND_API_KEY=re_...
# APP_URL=https://yourdomain.com
# CORS_ALLOW_ORIGIN=https://yourdomain.com                    # 生产必须设具体域名
# CRON_SECRET=<random>                                        # scheduled-purge 调用校验
# SUPABASE_STORAGE_BUCKET_REPORTS=reports
# PDF_SIGNED_URL_TTL_SECONDS=86400
#
# # PII 加密（详见 .trellis/spec/guides/privacy-pii.md）
# PII_ENCRYPTION_KEY=<base64 32 bytes random>
# PII_KEY_VERSION=1
# # 轮换期：PII_ENCRYPTION_KEY_V1=<旧 key>
